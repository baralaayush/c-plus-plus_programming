/*Q 10: Passing Arguments
Write three separate programs to swap two numbers using:
1. Pass by Value
2. Pass by Reference
3. Pass by Pointer
Compare the outputs.
*/
//pass by value
#include<iostream>
using namespace std;
void swap(int a,int b)
{
	a=a+b;
	b=a-b;
	a=a-b;
	
	cout<<"Swap number in swap function";
	cout<<a<<","<<b<<endl;
}
int main()
{
	int a,b;
	cout<<"Enter any two number";
	cin>>a>>b;
	cout<<"Number before swap in main function";
	cout<<a<<","<<b<<endl;
	swap(a,b);
	cout<<"Number after swap in main function";
	cout<<a<<","<<b;
	return 0;
}

//pass by reference
#include<iostream>
using namespace std;
void swap(int &a,int &b)
{
	a=a+b;
	b=a-b;
	a=a-b;
	
	cout<<"Swap number in swap function";
	cout<<a<<","<<b<<endl;
}
int main()
{
	int a,b;
	cout<<"Enter any two number";
	cin>>a>>b;
	cout<<"Number before swap in main function";
	cout<<a<<","<<b<<endl;
	swap(a,b);
	cout<<"Number after swap in main function";
	cout<<a<<","<<b;
	return 0;
}

//pass by pointer
#include<iostream>
using namespace std;
void swap(int *a,int *b)
{
	*a=*a+*b;
	*b=*a-*b;
	*a=*a-*b;
	
	cout<<"Swap number in swap function";
	cout<<*a<<","<<*b<<endl;
}
int main()
{
	int a,b;
	
	cout<<"Enter any two number";
	cin>>a>>b;
	
	cout<<"Number before swap in main function";
	cout<<a<<","<<b<<endl;
	
	swap(&a,&b);
	
	cout<<"Number after swap in main function";
	cout<<a<<","<<b;
	return 0;
}


