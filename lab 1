/*Q 5: Number Problems
Write separate programs to:
1. Find factorial of a number.
2. Find Fibonacci series up to N terms.
3. Check whether a number is prime.
4. Reverse a number.
5. Check palindrome number.
6. Find Armstrong number.
*/

#include<iostream>
#include<math.h>
using namespace std;

int fact(int num)
{
	int i;
	for(i=num-1; i>=1; i--)
	{
		num=num*i;
	}
	return num;
}

int fibo(int num)
{
	if(num==0)
	return 0;
	
	else if(num==1)
	return 1;
	
	else
	return fibo(num-1)+fibo(num-2);
	
}

int prime(int num)
{
	int i,count;
	for(i=1; i<=num; i++)
	{
		if(num%i==0)
		count ++;
	}
	if (count==2)
	return 0;
	else
	return 1;
}

int rev(int num)
{
	int rem,result=0;
	
	while(num!=0)
	{
		rem=num%10;
		result=result*10+rem;
		num=num/10;
	}
	return result;
}

int palin(int num)
{
	int ori=num;
	int rem,result=0;
	
	while(num!=0)
	{
		rem=num%10;
		result=result*10+rem;
		num=num/10;
	}
	
	if(result==ori)
	return 0;
	else
	return 1;
}

int arms(int num)
{
	int count=0;
	int ori=num;
	int rem,result=0;
	
	while(num!=0)
	{
		num=num/10;
		count ++;
	}
	num=ori;
	
	while(num!=0)
	{
		rem=num%10;
		result=result+pow(rem,count);
		num=num/10;	
	}
	
	if(result==ori)
	return 0;
	else 
	return 1;
}

int main()
{
	char c;
	int num,i;
	
	cout<<"Enter any number";
	cin>>num;
	
	cout<<"Select operation(F,f,p,R,P,A for Factorial,Fibonacii,Prime Check,Reverse,Palindrome Check,Armstrong Check)";
	cin>>c;
	
	switch(c){
	
	case 'F':
	cout<<"Factorial of "<<num<<" is: "<<fact(num);
	break;
	
	case 'f':
	cout<<"Fibonacci series upto "<<num<<"th term are: ";
	for(i=0; i<num; i++)
	{
		cout<<fibo(i)<<",";
	}
	break;
	
	case 'p':	
	cout<<"The given number "<<num<<" is ";
	if(prime(num)==0)
	cout<<"prime";
	else
	cout<<"not a prime";
	break;
	
	case 'R':
	cout<<"The reverse of given number is "<<rev(num);
	break;
	
	case 'P':
	cout<<"The given number is ";
	if(palin(num)==0)
	cout<<"palindrome";
	else
	cout<<"not palindrome";
	break;
	
	case 'A':
	cout<<"The given number is ";
	if(arms(num)==0)
	cout<<"armstrong";
	else
	cout<<"not armstrong";
	break;
	
	default:
	cout<<"Invalid operation choosing to perfrom";
	}
	
	return 0;
}


