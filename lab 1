int main()
{
	int n,temp;
	int i,j=0;
	cout<<"Enter size of array:";
	cin>>n;
	int a[n];
	int *x;
	x=a;
	cout<<"Enter array element:";
	for(i=0; i<n; i++)
	{
		cin>>*(x+i);
	}
	
	for(i=n-1; j<i; i--) 
	{
		temp=*(x+j);
		*(x+j)=*(x+i);
		*(x+i)=temp;
		j++;
	}
	cout<<"The element in reverse order is:";
	for(i=0; i<n; i++)
	{
		cout<<*(x+i);
	}
	return 0;
}


/*Write a function that accepts an array and finds:
• Maximum element
• Minimum element
• Average 
*/

#include<iostream>
using namespace std;
void max(int a[], int n)
{
	int i,max=*a;
	for(i=0; i<n; i++)
	{
		if(max<*(a+i))
		max=*(a+i);
	}
	cout<<"The maximum element is: "<<max<<endl;
}

void min(int a[], int n)
{
	int i,min=*a;
	for(i=0; i<n; i++)
	{
		if(min>*(a+i))
		min=*(a+i);
	}
	cout<<"The minimum element is: "<<min<<endl;
}

void avg(int a[], int n)
{
	int i,sum=0;
	for(i=0; i<n; i++)
	{
		sum=sum+*(a+i);
	}
	float avg=sum/n;
	cout<<"The average of element is: "<<avg;
}

int main()
{
	int n;
	int i;
	cout<<"Enter size of array:";
	cin>>n;
	int a[n];
	cout<<"Enter array element:";
	for(i=0; i<n; i++)
	{
		cin>>a[i];
	}
	max(a,n);
	min(a,n);
	avg(a,n);
	return 0;
}

//Write a program to add two matrices using functions
#include<iostream>
using namespace std;
void add(int row, int col,int *mat1,int *mat2)
{
	int i,j;
	int k=0;
	int mat[row][col];
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			mat[i][j]=*(mat1+k)+*(mat2+k);
			k++;
		}
	}
	
	cout<<"The addition of matrix is:"<<endl;
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			cout<<mat[i][j]<<'\t';
		}
		cout<<endl;
	}
}

int main()
{
	int row,col;
	int i,j;
	cout<<"Enter size of matrix(row,col):";
	cin>>row>>col;
	int mat1[row][col];
	int mat2[row][col];
	
	cout<<"Enter element for first matrix:";
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			cin>>mat1[i][j];
		}
	}
		
	cout<<"Enter element for second matrix:";
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			cin>>mat2[i][j];
		}
	}
	
	add(row, col, &mat1[0][0], &mat2[0][0]);
	return 0;
}

//Write a program to multiply two matrices using functions.
#include<iostream>
using namespace std;
void multiply(int row1, int col1, int row2, int col2, int mat1[100][100],int mat2[100][100])
{
    int i, j, k;
    // We use a flattened 1D array for the result to keep it simple
    int mul[row1][col2];

    // Matrix Multiplication Logic
    for(i = 0; i < row1; i++)
    {
        for(j = 0; j < col2; j++)
        {	mul[i][j]=0;
            for(k = 0; k < row2; k++)
            {
               mul[i][j]=mul[i][j]+mat1[i][k]*mat2[k][j];
            }
        }
    }
    
    cout << "The multiplication of matrix is:" << endl;
    for(i = 0; i < row1; i++)
    {
        for(j = 0; j < col2; j++)
        {
            cout << mul[i][j] << '\t';
        }
        cout << endl;
    }
}

int main()
{
	int row1,col1;
	int row2,col2;
	cout<<"Enter size of first matrix(row,col):";
	cin>>row1>>col1;
	cout<<"Enter size of second matrix(row,col):";
	cin>>row2>>col2;
	if(col1!=row2)
	{
		cout<<"Column of first matrix must be equal to row of second matrix";
		return 0;
	}
	int i,j;
	int mat1[100][100];
	int mat2[100][100];
		
	cout<<"Enter element for first matrix:";
	for(i=0; i<row1; i++)
	{
		for(j=0; j<col1; j++)
		{
			cin>>mat1[i][j];
		}
	}
		
	cout<<"Enter element for second matrix:";
	for(i=0; i<row2; i++)
	{
		for(j=0; j<col2; j++)
		{
			cin>>mat2[i][j];
		}
	}
	
	multiply(row1,col1,row2,col2,mat1,mat2);
	return 0;
}

